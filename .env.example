# LLM provider API keys (at least one required)
ANTHROPIC_API_KEY=sk-ant-...
DEEPSEEK_API_KEY=sk-...
GOOGLE_API_KEY=
OPENAI_API_KEY=sk-...
PERPLEXITY_API_KEY=pplx-...

# Hugging Face token (for downloading TTS models)
HF_TOKEN=hf_...

# PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://podcast:podcast@localhost:9002/podcast

# Where episode audio files are stored
AUDIO_DIR=/data/audio

# Directory for voice reference .wav samples
VOICE_REFS_DIR=/app/voice_refs

# Public URL (used in RSS feed links)
BASE_URL=http://localhost:9001

# Optional password for mutating API endpoints
API_PASSWORD=

# Auth (optional)
ALLOWED_SUB=
SESSION_SECRET=
